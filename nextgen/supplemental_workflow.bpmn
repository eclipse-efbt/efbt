    <bpmn2:subProcess id="SubProcess_Task4" name="Execute and Validate with Test Suites">
      <bpmn2:documentation><![CDATA[Execute the generated transformation code against test data and validate the results. Discovers test suites and runs them to verify correctness of the entire pipeline.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Execute and Validate with Test Suites]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_3F6B9601-F2AC-47BD-A002-F9D4185F733A</bpmn2:incoming>
      <bpmn2:sequenceFlow id="Flow_T4_1" sourceRef="Task4_Start" targetRef="Task4_DiscoverSuites"/>
      <bpmn2:sequenceFlow id="_FFC412C9-E9D8-4F6C-AE67-CBA4275C124A" sourceRef="SubProcess_ExecuteTestSuites" targetRef="Task4_End"/>
      <bpmn2:sequenceFlow id="_0ADF303E-0540-48D3-9726-560BF1550341" sourceRef="Task4_DiscoverSuites" targetRef="SubProcess_ExecuteTestSuites"/>
      <bpmn2:startEvent id="Task4_Start" name="Begin Testing">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Begin Testing]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:outgoing>Flow_T4_1</bpmn2:outgoing>
      </bpmn2:startEvent>
      <bpmn2:task id="Task4_DiscoverSuites" name="Discover Available Test Suites">
        <bpmn2:documentation><![CDATA[Scan the chosen  tests repository for available test suites. Each suite must contain a  file defining the set of tests, and each test must have example input data (like loans and bonds) and an expected result (such as a value for a specific report cell)]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Discover Available Test Suites]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T4_1</bpmn2:incoming>
        <bpmn2:outgoing>_0ADF303E-0540-48D3-9726-560BF1550341</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:endEvent id="Task4_End" name="Task 4 Complete">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Task 4 Complete]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>_FFC412C9-E9D8-4F6C-AE67-CBA4275C124A</bpmn2:incoming>
      </bpmn2:endEvent>
      <bpmn2:subProcess id="SubProcess_ExecuteTestSuites" name="Execute Test Suites">
        <bpmn2:documentation><![CDATA[Iterate over each discovered test suite and execute its tests using the RegulatoryTemplateTestRunner.]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Execute Test Suites]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>_0ADF303E-0540-48D3-9726-560BF1550341</bpmn2:incoming>
        <bpmn2:outgoing>_FFC412C9-E9D8-4F6C-AE67-CBA4275C124A</bpmn2:outgoing>
        <bpmn2:sequenceFlow id="Flow_TS_1" sourceRef="TestSuites_Start" targetRef="Task4_LoadConfig"/>
        <bpmn2:sequenceFlow id="Flow_TS_2" sourceRef="Task4_LoadConfig" targetRef="Task4_RunTests"/>
        <bpmn2:sequenceFlow id="Flow_TS_3" sourceRef="Task4_RunTests" targetRef="Task4_RecordResults"/>
        <bpmn2:sequenceFlow id="Flow_TS_End" sourceRef="Task4_RecordResults" targetRef="TestSuites_End"/>
        <bpmn2:startEvent id="TestSuites_Start" name="Begin Iteration">
          <bpmn2:extensionElements>
            <drools:metaData name="elementname">
              <drools:metaValue><![CDATA[Begin Iteration]]></drools:metaValue>
            </drools:metaData>
          </bpmn2:extensionElements>
          <bpmn2:outgoing>Flow_TS_1</bpmn2:outgoing>
        </bpmn2:startEvent>
        <bpmn2:task id="Task4_LoadConfig" name="Load Test Suite Configuration">
          <bpmn2:documentation><![CDATA[Load a test]]></bpmn2:documentation>
          <bpmn2:extensionElements>
            <drools:metaData name="elementname">
              <drools:metaValue><![CDATA[Load Test Suite Configuration]]></drools:metaValue>
            </drools:metaData>
          </bpmn2:extensionElements>
          <bpmn2:incoming>Flow_TS_1</bpmn2:incoming>
          <bpmn2:outgoing>Flow_TS_2</bpmn2:outgoing>
        </bpmn2:task>
        <bpmn2:task id="Task4_RunTests" name="Execute Test">
          <bpmn2:documentation><![CDATA[Load the inut data, Execute the relevant generated executable code, compare the result with the expected result.]]></bpmn2:documentation>
          <bpmn2:extensionElements>
            <drools:metaData name="elementname">
              <drools:metaValue><![CDATA[Execute Test]]></drools:metaValue>
            </drools:metaData>
          </bpmn2:extensionElements>
          <bpmn2:incoming>Flow_TS_2</bpmn2:incoming>
          <bpmn2:outgoing>Flow_TS_3</bpmn2:outgoing>
        </bpmn2:task>
        <bpmn2:task id="Task4_RecordResults" name="Record Test Results">
          <bpmn2:documentation><![CDATA[Record  pass fail for the test, if the test failed record the expected result and the actual result.]]></bpmn2:documentation>
          <bpmn2:extensionElements>
            <drools:metaData name="elementname">
              <drools:metaValue><![CDATA[Record Test Results]]></drools:metaValue>
            </drools:metaData>
          </bpmn2:extensionElements>
          <bpmn2:incoming>Flow_TS_3</bpmn2:incoming>
          <bpmn2:outgoing>Flow_TS_End</bpmn2:outgoing>
        </bpmn2:task>
        <bpmn2:endEvent id="TestSuites_End" name="Suite Complete">
          <bpmn2:extensionElements>
            <drools:metaData name="elementname">
              <drools:metaValue><![CDATA[Suite Complete]]></drools:metaValue>
            </drools:metaData>
          </bpmn2:extensionElements>
          <bpmn2:incoming>Flow_TS_End</bpmn2:incoming>
        </bpmn2:endEvent>
      </bpmn2:subProcess>
    </bpmn2:subProcess>
