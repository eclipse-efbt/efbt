      <bpmn2:sequenceFlow id="Flow_T1_5" sourceRef="Task1_ImportHierarchies" targetRef="Task1_ProcessSemantic"/>
      <bpmn2:sequenceFlow id="Flow_T1_End" sourceRef="Task1_ProcessSemantic" targetRef="Task1_End"/>
      <bpmn2:startEvent id="Task1_Start" name="Begin Task 1">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Begin Task 1]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:outgoing>Flow_T1_1</bpmn2:outgoing>
      </bpmn2:startEvent>
      <bpmn2:task id="Task1_DeleteDB" name="Delete Existing BIRD Metadata">
        <bpmn2:documentation><![CDATA[Clear all existing BIRD metadata from the database to ensure a clean import. Entry point: RunDeleteBirdMetadataDatabase.run_delete_bird_metadata_database()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Delete Existing BIRD Metadata]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T1_1</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T1_2</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:task id="Task1_ImportInputModel" name="Import Input Layer Cube Structures">
        <bpmn2:documentation><![CDATA[Import the input layer model from SQL Developer EIL/ELDM files. Creates CUBE, CUBE_STRUCTURE, and CUBE_STRUCTURE_ITEM records. Entry point: RunImportInputModelFromSQLDev.ready()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Import Input Layer Cube Structures]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T1_2</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T1_3</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:task id="Task1_GenerateTemplates" name="Import Report Template Definitions">
        <bpmn2:documentation><![CDATA[Import report templates from the BIRD website or GitHub repository. Defines the output layer table structures. Entry point: RunImportReportTemplatesFromWebsite.run_import()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Import Report Template Definitions]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T1_3</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T1_4</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:task id="Task1_ImportHierarchies" name="Import Member Hierarchy Definitions">
        <bpmn2:documentation><![CDATA[Import member hierarchy definitions from the BIRD website. Defines parent-child relationships between domain members. Entry point: RunImportHierarchiesFromWebsite.import_hierarchies()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Import Member Hierarchy Definitions]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T1_4</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T1_5</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:task id="Task1_ProcessSemantic" name="Import Semantic Integration Mappings">
        <bpmn2:documentation><![CDATA[Import variable and member mappings (semantic integrations) from the BIRD website. These define how input layer variables map to output layer variables. Entry point: RunImportSemanticIntegrationsFromWebsite.import_mappings_from_website()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Import Semantic Integration Mappings]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T1_5</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T1_End</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:endEvent id="Task1_End" name="Task 1 Complete">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Task 1 Complete]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T1_End</bpmn2:incoming>
      </bpmn2:endEvent>
    </bpmn2:subProcess>
    <bpmn2:subProcess id="SubProcess_Task2" name="Task 2: Generate Transformation Rule Metadata">
      <bpmn2:documentation><![CDATA[Create the abstract transformation rules that define how data flows from input layer tables to output layer report cells. These rules are framework-independent metadata.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Task 2: Generate Transformation Rule Metadata]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
