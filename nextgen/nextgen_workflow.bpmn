      <bpmn2:sequenceFlow id="_A1F9F338-A92D-4451-9BBB-357E5A4045F7" sourceRef="_C06DFA0F-5624-41A8-B5B0-6CEC03462E6B" targetRef="Task2_GenerateFilters">
        <bpmn2:extensionElements>
          <drools:metaData name="isAutoConnection.target">
            <drools:metaValue><![CDATA[true]]></drools:metaValue>
