          <bpmn2:dataInput id="_4D26F51A-B8DC-4503-9A6F-9352CA7BA9BD_SkippableInputX" drools:dtype="Object" itemSubjectRef="__4D26F51A-B8DC-4503-9A6F-9352CA7BA9BD_SkippableInputXItem" name="Skippable"/>
