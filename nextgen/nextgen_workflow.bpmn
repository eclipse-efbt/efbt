    <bpmn2:subProcess id="SubProcess_Task1" name="Task 1: Import BIRD Metadata into Database">
      <bpmn2:documentation><![CDATA[Import and configure the core SMCubes data model including input layer structures, report templates, hierarchies, and semantic integration mappings.]]></bpmn2:documentation>
