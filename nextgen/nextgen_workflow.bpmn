      <bpmn2:task id="Task_RetrieveArtifacts" name="Download BIRD Artefacts from Source">
        <bpmn2:documentation><![CDATA[Download technical export files, configuration files, and test suites from configured sources (BIRD website or GitHub repositories).]]></bpmn2:documentation>
