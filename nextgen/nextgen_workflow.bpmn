      </bpmn2:startEvent>
      <bpmn2:task id="Task2_GenerateFilters" name="Generate Filters and Aggregation Rules">
        <bpmn2:documentation><![CDATA[Create filter rules from the joins configuration files. Filters define row-level selection criteria for input layer data. Entry point: RunCreateFilters.run_create_filters()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Generate Filters and Aggregation Rules]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>_A1F9F338-A92D-4451-9BBB-357E5A4045F7</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T2_2</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:task id="Task2_CreateJoinsMetadata" name="Create Joins Metadata (Input-to-Output Layer)">
        <bpmn2:documentation><![CDATA[Generate transformation metadata from joins configuration CSV files. Defines how input layer tables join together and map to output layer structures. Entry point: RunCreateJoinsMetadata.run_create_joins_meta_data()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Create Joins Metadata (Input-to-Output Layer)]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T2_2</bpmn2:incoming>
        <bpmn2:outgoing>_6C00AFDE-85B8-4F47-BB38-172F0AFAB8C9</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:endEvent id="Task2_End" name="Task 2 Complete">
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Task 2 Complete]]></drools:metaValue>
