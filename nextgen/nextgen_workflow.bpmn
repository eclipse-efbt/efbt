      </bpmn2:task>
      <bpmn2:task id="Task_CreateModels" name="Generate Database Schema from Artefacts">
        <bpmn2:documentation><![CDATA[Generate Django ORM models from downloaded technical export metadata. Creates bird_data_model.py and updates admin.py registrations.]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Generate Database Schema from Artefacts]]></drools:metaValue>
