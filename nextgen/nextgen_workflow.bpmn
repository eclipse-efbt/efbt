        <bpmn2:incoming>_2F97FAAD-38D7-4864-8E3D-361661EDD550</bpmn2:incoming>
      </bpmn2:endEvent>
    </bpmn2:subProcess>
    <bpmn2:subProcess id="SubProcess_Task3" name="Task 3: Generate Executable Transformation Code">
      <bpmn2:documentation><![CDATA[Generate executable Python code from the abstract transformation rules created in Task 2. Produces runnable filter and join modules.]]></bpmn2:documentation>
      <bpmn2:extensionElements>
