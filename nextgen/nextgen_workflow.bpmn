      <bpmn2:task id="Task3_GenerateFilterCode" name="Generate Executable Filter Code">
        <bpmn2:documentation><![CDATA[Generate executable Python filter modules from database-stored filter definitions. Creates Python files that implement row-level data filtering. Entry point: RunCreateExecutableFilters.run_create_executable_filters_from_db()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
            <drools:metaValue><![CDATA[Generate Executable Filter Code]]></drools:metaValue>
          </drools:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>Flow_T3_1</bpmn2:incoming>
        <bpmn2:outgoing>Flow_T3_2</bpmn2:outgoing>
      </bpmn2:task>
      <bpmn2:task id="Task3_GenerateJoinCode" name="Generate Executable Join Code">
        <bpmn2:documentation><![CDATA[Generate executable Python join/transformation modules from database-stored joins metadata. Creates Python files that implement data transformations from input to output layer. Entry point: RunCreateExecutableJoins.create_python_joins_from_db()]]></bpmn2:documentation>
        <bpmn2:extensionElements>
          <drools:metaData name="elementname">
